# =============================================================================
# Doby — local secrets (NEVER commit this file)
# =============================================================================
# Pick the section matching your provider in config.yaml, paste your key,
# then `docker compose restart doby` (or just `Ctrl+D` and re-run `doby`).
# =============================================================================

# ── GitHub Copilot ─────────────────────────────────────────────────────────
# For OAuth (recommended), leave blank and use `/model` inside the chat to
# do the device-code flow. The token lands in data/auth.json.
# If you'd rather use a token directly, uncomment one of these:
# COPILOT_GITHUB_TOKEN=
# GH_TOKEN=
# GITHUB_TOKEN=

# ── OpenRouter ─────────────────────────────────────────────────────────────
# https://openrouter.ai/keys → "Create Key"
# OPENROUTER_API_KEY=

# ── Google AI Studio (Gemini) ──────────────────────────────────────────────
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# ── Anthropic direct API ───────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
# This is a real API key (sk-ant-api03-...), NOT a Claude Pro/Max OAuth token.
# ANTHROPIC_API_KEY=

# ── Doby toggles ───────────────────────────────────────────────────────────
HERMES_TELEMETRY=0
